    print(f"  {title}")
    print(BLOCK)

def print_section(title: str) -> None:
    print()
    print(LINE)
    print(f"  {title}")
    print(LINE)

# ─────────────────────────────────────────────────────────────────────────────
# LAYER 4 IMPLEMENTATION: Dynamic Context Window Optimizer
# Based on the StreamingLLM / H2O principle:
#   keep attention sinks (first N tokens) + recent window,
#   map this to a concrete num_ctx ceiling per model.
# ─────────────────────────────────────────────────────────────────────────────

def kv_cache_bytes(num_ctx: int, params_b: float, quant: str = "q4_0") -> int:
    """
    Estimate KV cache memory for a given context length.

    Formula derived from transformer KV cache structure:
      KV_bytes = 2 × num_layers × num_ctx × d_head × dtype_bytes
               ≈ num_ctx × params_B × kv_ratio × dtype_bytes

    We approximate num_layers and d_head from params_B using
    empirical scaling laws (Chinchilla-adjacent):
      num_layers ≈ 4.0 × params_B^0.31
      d_head     ≈ 128  (stable across 7B–70B)
      num_heads  ≈ 32   (stable at these scales)
    """
    num_layers = max(8, int(4.0 * (params_b ** 0.31) * 4))
    d_kv       = 128
    num_heads  = 32
    dtype_bytes = 0.5 if "q4" in quant else (1.0 if "q8" in quant else 2.0)
    # MLA compresses KV to a latent of dimension d_kv/8
    mla_factor = 0.07 if quant.startswith("mla_") else 1.0
    kv = 2 * num_layers * num_heads * d_kv * num_ctx * dtype_bytes * mla_factor
    return int(kv)

def model_weight_bytes(params_b: float, quant: str) -> int:
    bpp = QUANT_BPP.get(quant.lower(), QUANT_BPP["q4_k_m"])
    return int(params_b * 1e9 * bpp)

def optimal_context(params_b: float, quant: str, budget_b: int,
                    target_fill: float = 0.85,
                    min_ctx: int = 512, max_ctx: int = 131072) -> Tuple[int, float]:
    """
    Layer 4: Binary-search the largest context window that keeps
    total memory (weights + KV cache) under budget × target_fill.

    Returns (optimal_num_ctx, fill_ratio).
    """
    weight_b   = model_weight_bytes(params_b, quant)
    headroom_b = int(budget_b * target_fill) - weight_b

    if headroom_b <= 0:
        return min_ctx, weight_b / budget_b

    # Binary search over context lengths
    lo, hi = min_ctx, max_ctx
    best = min_ctx
    while lo <= hi:
        mid = (lo + hi) // 2
        kv  = kv_cache_bytes(mid, params_b, quant)
        if kv <= headroom_b:
            best = mid
            lo   = mid + 1
        else:
            hi   = mid - 1

    total_used = weight_b + kv_cache_bytes(best, params_b, quant)
    fill       = total_used / budget_b
    return best, fill

