def cmd_context_fit(args: argparse.Namespace) -> int:
    model   = args.model
    target  = args.target
    bgt     = budget_bytes()

    print_header(f"CONTEXT WINDOW OPTIMIZER · {model}")

    if bgt is None:
        print("  [!] No budget data. Run `mlm-memory analyze` first.")
        return 1

    entry    = next((m for m in MODEL_CATALOGUE if m.tag == model), None)
    params_b = entry.params_b if entry else args.params_b
    quant    = (entry.quant if entry else args.quant).lower()
    arch     = entry.arch if entry else "transformer"

    if params_b is None:
        print("  [!] --params-b required for models not in catalogue.")
        return 1

    print(f"  Budget          : {gib(bgt)}")
    print(f"  Model           : {model}  ({params_b}B, {arch}, {quant})")
    print(f"  Target fill     : {target:.0%}")

    print_section("Context Window vs Memory Trade-off")
    print(f"  {'num_ctx':>10}  {'KV cache':>10}  {'Total':>10}  {'Fill':>6}  Status")
    print(f"  {'':-<10}  {'':-<10}  {'':-<10}  {'':-<6}  ------")

    weight_b = model_weight_bytes(params_b, quant)
    for ctx in [512, 1024, 1280, 1536, 2048, 3072, 4096, 8192, 16384, 32768, 65536]:
        kv   = kv_cache_bytes(ctx, params_b, quant)
        total = weight_b + kv
        fill  = total / bgt
        if fill > 1.20:
            break
        status = "✓ OK" if fill <= target else ("⚠ TIGHT" if fill <= 1.0 else "✗ OOM")
        marker = " ◄" if abs(fill - target) < 0.05 else ""
        print(f"  {ctx:>10,}  {gib(kv):>10}  {gib(total):>10}  {fill:>5.1%}  {status}{marker}")

    opt_ctx, opt_fill = optimal_context(params_b, quant, bgt, target)
    print_section("Recommendation")
    print(f"  PARAMETER num_ctx {opt_ctx}   ← optimal for {target:.0%} budget target")
    print(f"  Fill ratio        {opt_fill:.1%}")
    print(f"  KV cache size     {gib(kv_cache_bytes(opt_ctx, params_b, quant))}")

    if arch == "mla":
        print(f"\n  ★  MLA model: KV estimates are conservative.")
        print(f"     Actual KV will be ~7% of these values. You can run ctx x14 larger.")
        mla_ctx = min(131072, opt_ctx * 14)
        print(f"     Effective MLA-adjusted context: {mla_ctx:,}")

    return 0


