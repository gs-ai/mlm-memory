def cmd_preflight(args: argparse.Namespace) -> int:
    model   = args.model
    quant   = args.quant.lower()
    bgt     = budget_bytes()
    total   = total_ram_bytes()
    unified = is_unified_memory()

    print_header(f"PRE-FLIGHT VALIDATOR · {model}")

    if bgt is None or total is None:
        print("  [!] Cannot determine system memory. Run `mlm-memory analyze` first.")
        return 1

    print(f"  Total RAM       : {gib(total)}")
    print(f"  Effective budget: {gib(bgt)}  (unified={unified})")
    print(f"  Model           : {model}")
    print(f"  Quant assumed   : {quant}")

    # Try to find the model in the catalogue
    entry = next((m for m in MODEL_CATALOGUE if m.tag == model), None)
    params_b = entry.params_b if entry else args.params_b
    arch     = entry.arch     if entry else "transformer"

    if params_b is None:
        print("\n  [!] --params-b required when model is not in the built-in catalogue.")
        return 1

    print(f"  Architecture    : {arch}")
    print(f"  Parameters      : {params_b}B")

    weight_b = model_weight_bytes(params_b, quant)
    print_section("Weight Memory")
    print(f"  Model weights   : {gib(weight_b)}")
    print(f"  Budget remaining: {gib(max(0, bgt - weight_b))}")

    if weight_b > bgt:
        shortfall = weight_b - bgt
        print(f"\n  ✗  WILL NOT FIT — {gib(shortfall)} over budget")
        print(f"     Suggestion: switch to a lower quantization or smaller model.")
        _suggest_alternatives(params_b, bgt, quant)
        return 2

    # Find optimal context
    opt_ctx, fill = optimal_context(params_b, quant, bgt, target_fill=0.88)
    kv_b = kv_cache_bytes(opt_ctx, params_b, quant)

    print_section("KV Cache & Context Window (Layer 4 Analysis)")
    print(f"  Optimal num_ctx : {opt_ctx:,} tokens")
    print(f"  KV cache at ctx : {gib(kv_b)}")
    print(f"  Total projected : {gib(weight_b + kv_b)}")
    print(f"  Budget fill     : {fill:.1%}")

    # Pressure verdict
    print_section("Verdict")
    if fill < 0.75:
        verdict = "✓  COMFORTABLE — model fits with headroom"
        code = 0
    elif fill < 0.92:
        verdict = "⚠  TIGHT — will load but watch memory pressure"
        code = 0
    else:
        verdict = "✗  CRITICAL — likely OOM during generation at full context"
        code = 2

    print(f"  {verdict}")

    if arch == "mla":
        print(f"\n  ★  MLA ARCHITECTURE BONUS (Layer 6)")
        print(f"     DeepSeek MLA compresses KV to ~7% of standard size.")
        print(f"     Effective fit is significantly better than these estimates.")

    if arch in ("ssm", "hybrid"):
        print(f"\n  ★  STATE SPACE MODEL (Layer 7)")
        print(f"     No KV cache at all. Context length has O(1) memory cost.")
        print(f"     This model can run at any context length within weight budget.")

    print_section("Recommended Modelfile Parameters")
    print(f"  PARAMETER num_ctx   {opt_ctx}")
    kv_quant = "q4_0" if arch != "mla" else "f16"  # MLA is already compressed
    print(f"  OLLAMA_KV_CACHE_TYPE={kv_quant}")
    print(f"  OLLAMA_FLASH_ATTENTION=1")
    recommended_batch = min(512, max(32, opt_ctx // 16))
    print(f"  PARAMETER num_batch {recommended_batch}")

    return code


def _suggest_alternatives(params_b: float, budget_b: int, current_quant: str) -> None:
    print("\n  Alternative quantizations that may fit:")
    quant_order = ["q4_k_m", "q4_0", "q3_k_m", "q3_k_s", "q2_k"]
    found = False
    for q in quant_order:
        w = model_weight_bytes(params_b, q)
        if w < budget_b:
            ctx, _ = optimal_context(params_b, q, budget_b)
            print(f"    {q:<12} → weights={gib(w)}, max_ctx={ctx:,}")
            found = True
    if not found:
        smaller = [m for m in MODEL_CATALOGUE if m.vram_gib * 1.074e9 < budget_b]
        if smaller:
            smaller.sort(key=lambda m: m.vram_gib, reverse=True)
            print(f"\n  Largest model that fits: {smaller[0].tag}  ({smaller[0].vram_gib:.1f} GiB)")


