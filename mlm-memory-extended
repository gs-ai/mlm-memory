# ── Helpers ───────────────────────────────────────────────────────────────────

def gib(b: float) -> str:
    return f"{b / (1024**3):.1f} GiB"

def load_analysis() -> Optional[dict]:
    if not ANALYSIS_PATH.exists():
        return None
    try:
        return json.loads(ANALYSIS_PATH.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return None

def safe_run(cmd: List[str], timeout: float = 6) -> subprocess.CompletedProcess:
    try:
        return subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return subprocess.CompletedProcess(cmd, returncode=1, stdout="", stderr="")

def resolve_ollama() -> Optional[str]:
    env_bin = os.environ.get("OLLAMA_BIN")
    if env_bin and Path(env_bin).exists():
        return env_bin
    return shutil.which("ollama")

def total_ram_bytes() -> Optional[int]:
    sys_name = platform.system()
    if sys_name == "Darwin":
        r = safe_run(["sysctl", "-n", "hw.memsize"])
        try:
            return int(r.stdout.strip())
        except ValueError:
            pass
    if sys_name == "Linux":
        mi = Path("/proc/meminfo")
        if mi.exists():
            for line in mi.read_text().splitlines():
                if line.startswith("MemTotal:"):
                    digits = re.findall(r"\d+", line)
                    if digits:
                        return int(digits[0]) * 1024
    return None

def available_ram_bytes() -> Optional[int]:
    sys_name = platform.system()
    if sys_name == "Linux":
        mi = Path("/proc/meminfo")
        if mi.exists():
            for line in mi.read_text().splitlines():
                if line.startswith("MemAvailable:"):
                    digits = re.findall(r"\d+", line)
                    if digits:
                        return int(digits[0]) * 1024
    if sys_name == "Darwin":
        r = safe_run(["vm_stat"])
        if r.returncode == 0:
            page_size = 4096
            pm = re.search(r"page size of (\d+)", r.stdout)
            if pm:
                page_size = int(pm.group(1))
            totals = 0
            for label in ["Pages free", "Pages speculative", "Pages inactive", "Pages purgeable"]:
                m = re.search(rf"{label}:\s+(\d+)", r.stdout)
                if m:
                    totals += int(m.group(1))
            return totals * page_size
    return None

def is_unified_memory() -> bool:
    analysis = load_analysis()
    if analysis:
        return analysis.get("host", {}).get("unified_memory", False)
    return platform.system() == "Darwin" and platform.machine().lower() == "arm64"

def budget_bytes() -> Optional[int]:
    analysis = load_analysis()
    if analysis:
        pb = analysis.get("profile", {}).get("estimated_budget_bytes")
        if pb:
            return int(pb)
    total = total_ram_bytes()
    if not total:
        return None
    ratio = 0.52 if is_unified_memory() else 0.42
    avail = available_ram_bytes()
    budget = int(total * ratio)
    if avail:
        budget = min(budget, int(avail * 0.88))
    return budget

def print_header(title: str) -> None:
    print()
