# ─────────────────────────────────────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="mlm-memory-extended",
        description="Layer 4–7 extension for gs-ai/mlm-memory",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Commands:
  preflight     Validate model fit BEFORE loading (prevents OOM crashes)
  recommend     Hardware-aware model list with MLA/SSM architecture tags
  context-fit   Dynamic optimal context window calculator (Layer 4)
  monitor       Real-time memory pressure display

Examples:
  ./mlm-memory-extended preflight --model deepseek-r1:14b
  ./mlm-memory-extended preflight --model my-custom:7b --params-b 7 --quant q4_k_m
  ./mlm-memory-extended recommend
  ./mlm-memory-extended context-fit --model qwen2.5:14b --target 0.85
  ./mlm-memory-extended monitor --interval 2
        """,
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # preflight
    pf = sub.add_parser("preflight", help="Pre-flight model fit validator")
    pf.add_argument("--model",    required=True, help="Model tag (e.g. deepseek-r1:14b)")
    pf.add_argument("--params-b", type=float, default=None,
                    dest="params_b", help="Parameter count in billions (auto if in catalogue)")
    pf.add_argument("--quant",    default="q4_k_m",
                    help="Quantization level (default: q4_k_m)")

    # recommend
    sub.add_parser("recommend", help="Hardware-aware model recommender")

    # context-fit
    cf = sub.add_parser("context-fit", help="Optimal context window calculator")
    cf.add_argument("--model",    required=True, help="Model tag")
    cf.add_argument("--params-b", type=float, default=None, dest="params_b")
    cf.add_argument("--quant",    default="q4_k_m")
    cf.add_argument("--target",   type=float, default=0.85,
                    help="Budget fill target 0.0–1.0 (default: 0.85)")

    # monitor
    mon = sub.add_parser("monitor", help="Real-time memory pressure monitor")
    mon.add_argument("--interval", type=float, default=1.0,
                     help="Poll interval in seconds (default: 1.0)")

    return parser


def main() -> int:
    parser = build_parser()
    args   = parser.parse_args()

    dispatch = {
        "preflight":   cmd_preflight,
        "recommend":   cmd_recommend,
        "context-fit": cmd_context_fit,
        "monitor":     cmd_monitor,
    }

    fn = dispatch.get(args.command)
    if fn is None:
        parser.print_help()
        return 1

    return fn(args)


if __name__ == "__main__":
    sys.exit(main())
