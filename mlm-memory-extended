# COMMAND: monitor
# Real-time memory pressure display — polls every N seconds
# ─────────────────────────────────────────────────────────────────────────────

def _mem_pressure_darwin() -> Tuple[float, float, str]:
    """Returns (used_gib, total_gib, pressure_label)"""
    r = safe_run(["vm_stat"])
    total_b = total_ram_bytes() or 0
    if r.returncode != 0 or not total_b:
        return 0.0, 0.0, "unknown"

    page_size = 4096
    pm = re.search(r"page size of (\d+)", r.stdout)
    if pm:
        page_size = int(pm.group(1))

    def pages(label: str) -> int:
        m = re.search(rf"{label}:\s+(\d+)", r.stdout)
        return int(m.group(1)) if m else 0

    wired        = pages("Pages wired down")
    active       = pages("Pages active")
    compressed   = pages("Pages occupied by compressor")
    speculative  = pages("Pages speculative")

    used_b  = (wired + active + compressed) * page_size
    total_g = total_b / (1024**3)
    used_g  = used_b  / (1024**3)
    pct     = used_g / total_g

    if pct < 0.65:   label = "NORMAL"
    elif pct < 0.82: label = "ELEVATED"
    elif pct < 0.92: label = "HIGH"
    else:            label = "CRITICAL"

    return used_g, total_g, label


def _mem_pressure_linux() -> Tuple[float, float, str]:
    mi = Path("/proc/meminfo")
    if not mi.exists():
        return 0.0, 0.0, "unknown"
    vals: Dict[str, int] = {}
    for line in mi.read_text().splitlines():
        parts = line.split(":", 1)
        if len(parts) != 2:
            continue
        digits = re.findall(r"\d+", parts[1])
        if digits:
            vals[parts[0].strip()] = int(digits[0]) * 1024
    total_b = vals.get("MemTotal", 0)
    avail_b = vals.get("MemAvailable", vals.get("MemFree", 0))
    used_b  = total_b - avail_b
    if not total_b:
        return 0.0, 0.0, "unknown"
    total_g = total_b / (1024**3)
    used_g  = used_b  / (1024**3)
    pct     = used_g / total_g
    if pct < 0.65:   label = "NORMAL"
    elif pct < 0.82: label = "ELEVATED"
    elif pct < 0.92: label = "HIGH"
    else:            label = "CRITICAL"
    return used_g, total_g, label


def _bar(pct: float, width: int = 40) -> str:
    filled = int(pct * width)
    empty  = width - filled
    bar    = "█" * filled + "░" * empty
    if pct > 0.92:   return f"\033[91m{bar}\033[0m"   # red
    elif pct > 0.82: return f"\033[93m{bar}\033[0m"   # yellow
    elif pct > 0.65: return f"\033[96m{bar}\033[0m"   # cyan
    else:            return f"\033[92m{bar}\033[0m"   # green


def cmd_monitor(args: argparse.Namespace) -> int:
    interval = args.interval
    sys_name = platform.system()

    print_header("REAL-TIME MEMORY PRESSURE MONITOR")
    print(f"  Polling every {interval}s. Press Ctrl+C to stop.\n")

    ollama_bin = resolve_ollama()
    bgt        = budget_bytes()

    try:
        while True:
            if sys_name == "Darwin":
                used, total, label = _mem_pressure_darwin()
            else:
                used, total, label = _mem_pressure_linux()

            pct = used / total if total else 0
            bar = _bar(pct)

            ts = time.strftime("%H:%M:%S")

            # Ollama processes
            ollama_procs = 0
            if ollama_bin:
                r = safe_run(["pgrep", "-c", "ollama"], timeout=2)
                try:
                    ollama_procs = int(r.stdout.strip())
                except ValueError:
                    pass

            budget_warn = ""
            if bgt and used * (1024**3) > bgt * 0.95:
                budget_warn = "  ⚠  OVER MLM BUDGET"

            sys.stdout.write(
                f"\r  [{ts}]  {bar}  {used:.1f}/{total:.1f} GiB  "
                f"{pct:.1%}  [{label}]  ollama_procs={ollama_procs}{budget_warn}    "
            )
            sys.stdout.flush()
            time.sleep(interval)

    except KeyboardInterrupt:
        print("\n\n  Monitor stopped.")

    return 0


