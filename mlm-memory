# GiB threshold below which a unified-memory host is considered "small"
# (e.g. standard 16 GiB M2 MacBook Air).  Used for profile selection and
# budget estimation throughout this file.
_SMALL_UNIFIED_GIB = 20
# Extended model-load timeout inserted into the scoped environment so that
