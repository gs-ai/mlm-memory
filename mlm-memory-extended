def cmd_recommend(args: argparse.Namespace) -> int:
    bgt     = budget_bytes()
    total   = total_ram_bytes()
    unified = is_unified_memory()

    print_header("HARDWARE-AWARE MODEL RECOMMENDER")

    if bgt is None:
        print("  [!] Cannot determine budget. Run `mlm-memory analyze` first.")
        return 1

    print(f"  Effective budget: {gib(bgt)}")
    print(f"  Unified memory  : {unified}")

    # Tiers
    tier_fit     : List[ModelEntry] = []
    tier_tight   : List[ModelEntry] = []
    tier_too_big : List[ModelEntry] = []

    for m in MODEL_CATALOGUE:
        vram_b = m.vram_gib * (1024**3)
        if vram_b <= bgt * 0.80:
            tier_fit.append(m)
        elif vram_b <= bgt * 1.05:
            tier_tight.append(m)
        else:
            tier_too_big.append(m)

    tier_fit.sort(key=lambda m: (m.vram_gib, m.arch != "mla"), reverse=True)

    arch_icon = {"mla": "★MLA", "ssm": "∞SSM", "hybrid": "⊕HYB",
                 "moe": "⊗MoE", "transformer": "    "}

    print_section("✓  Fits Comfortably")
    if not tier_fit:
        print("  None at this budget.")
    for m in tier_fit[:12]:
        icon = arch_icon.get(m.arch, "    ")
        opt_ctx, _ = optimal_context(m.params_b, m.quant, bgt)
        print(f"  {icon}  {m.tag:<35} {m.vram_gib:5.1f} GiB  ctx≤{opt_ctx:,}  {m.notes}")

    print_section("⚠  Tight Fit (may work with MMM tuning)")
    if not tier_tight:
        print("  None.")
    for m in tier_tight:
        icon = arch_icon.get(m.arch, "    ")
        print(f"  {icon}  {m.tag:<35} {m.vram_gib:5.1f} GiB  {m.notes}")

    print_section("Architecture Legend")
    print("  ★MLA = Multi-head Latent Attention (DeepSeek) — 93% KV reduction [Layer 6]")
    print("  ∞SSM = State Space Model — O(1) memory, no KV cache [Layer 7]")
    print("  ⊕HYB = Hybrid SSM+Attention (Jamba) — partial KV cache [Layer 7]")
    print("  ⊗MoE = Mixture of Experts — sparse activation, only ~25% params active")
    print("       = Standard transformer")

    print_section("Pull Commands")
    for m in tier_fit[:5]:
        print(f"  ollama pull {m.tag}")

    return 0


